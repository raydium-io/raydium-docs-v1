# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Internal architecture document — for contributors only, not user-facing.
# Root-anchored so the pattern doesn't accidentally match
# `protocol-overview/architecture.mdx` on case-insensitive filesystems (macOS APFS).
/ARCHITECTURE.mdx
/zh/ARCHITECTURE.mdx

# Draft content
drafts/
*.draft.mdx

# Trash directory for husks left behind by the en/ -> root i18n migration
# (the bind-mount used during that migration could not unlink directories,
# so the now-empty en/ skeleton was renamed here. Safe to `rm -rf` from a
# native shell.)
.legacy-en-trash/
